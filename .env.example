# Admin Dashboard Credentials
ADMIN_EMAIL=info@gather-eg.com
ADMIN_PASSWORD=change_this_password
ADMIN_SESSION_SECRET=replace_with_a_long_random_secret

# Site URL for metadata, canonical URLs, sitemap, and social previews
SITE_URL=https://gather-eg.com
# NEXT_PUBLIC_SITE_URL=https://gather-eg.com

# SMTP Mail Configuration (outbound transactional email)
SMTP_HOST=mail.gather-eg.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@gather-eg.com
SMTP_PASSWORD=
MAIL_FROM=Gather <info@gather-eg.com>
MAIL_TO=info@gather-eg.com
# Path to a custom TLS certificate for the SMTP server (used when the server uses a self-signed cert)
# MAIL_TLS_CERT=/etc/ssl/certs/mailcow.pem
# Set to "true" to skip SMTP TLS certificate validation (dev only — for self-signed certs)
# SMTP_TLS_INSECURE=false

# Odoo Integration
# ODOO_URL=https://your-odoo-instance.odoo.com
# ODOO_DB=your_database_name
# ODOO_USERNAME=your_odoo_username
# ODOO_API_KEY=your_odoo_api_key
# ODOO_PASSWORD=your_odoo_password
# Comma-separated list of allowed Odoo hostnames (default: localhost,127.0.0.1,::1,host.docker.internal)
# ALLOWED_ODOO_HOSTS=localhost,127.0.0.1,odoo.gather-eg.com
# Set to "true" to enable checkout auto-sync (default: disabled)
# ODOO_SYNC_ENABLED=false

# Secret for cron endpoint auth (POST /api/cron/odoo/sync-stock, /api/cron/odoo/pull-products)
# ODOO_CRON_SECRET=replace_with_a_random_secret

# Webhook receiver (POST /api/webhooks/odoo/product)
# ODOO_WEBHOOK_SECRET=replace_with_a_random_secret
# ODOO_WEBHOOK_ENABLED=false
